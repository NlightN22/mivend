node_modules/
dist/
# Defense-in-depth: composite tsc -b projects normally emit this inside dist/
# (already ignored above), but a misconfigured/relocated tsconfig.json can
# leave one at a package root instead — a stray one there gets picked up by
# tsc -b's up-to-date check and can make it silently skip a real build.
*.tsbuildinfo
tasks/
.tests/
docs/ai/

# Environment files — commit only .example variants
.env
.env.*
!.env.*.example
!.env.example

# Generated assets — no leading slash and a trailing /** so this matches at
# any depth (apps/server/static/assets/, etc.), not just repo-root static/assets/
**/static/assets/**
storybook-static/

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# GraphQL codegen output
src/api/generated/

# Claude Code local state — but NOT .claude/skills/ or the shared settings.json: skills are the
# canonical, repo-wide procedure source (AGENTS.md's "Testing requirements" points every agent,
# not just Claude Code, at .claude/skills/test-design/SKILL.md) and settings.json is checked-in
# project config, not personal state. Only settings.local.json (personal overrides) and any
# future genuinely local/generated Claude Code artifacts stay ignored.
.claude/*
!.claude/skills/
!.claude/settings.json

# Vendure instance-specific
.vendure/

# Playwright E2E
packages/e2e/.auth/
packages/e2e/playwright-report/
packages/e2e/test-results/

# StrykerJS mutation testing output (docs/testing-strategy.md "Mutation testing")
reports/mutation/
.stryker-tmp/
