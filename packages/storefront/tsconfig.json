{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "jsx": "preserve",
        "jsxImportSource": "vue",
        "useDefineForClassFields": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "types": ["vite/client"]
    },
    "include": ["src/**/*", "src/**/*.vue"],
    "exclude": ["node_modules", "dist"]
}
