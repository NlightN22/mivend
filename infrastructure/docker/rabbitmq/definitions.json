{
    "rabbit_version": "3.12.0",
    "rabbitmq_version": "3.12.0",
    "product_name": "RabbitMQ",
    "product_version": "3.12.0",
    "users": [
        {
            "name": "mivend",
            "password_hash": "yv66vluY3JJL0L9znAs2TwBPlQ0Ldd8/taIMIwdmHtGZvIH4",
            "hashing_algorithm": "rabbit_password_hashing_sha256",
            "tags": "administrator"
        }
    ],
    "vhosts": [{ "name": "/" }],
    "permissions": [
        {
            "user": "mivend",
            "vhost": "/",
            "configure": ".*",
            "write": ".*",
            "read": ".*"
        }
    ],
    "topic_permissions": [],
    "parameters": [],
    "global_parameters": [],
    "policies": [
        {
            "vhost": "/",
            "name": "ha-sync",
            "pattern": "^sync\\.",
            "definition": { "ha-mode": "all", "ha-sync-mode": "automatic" },
            "priority": 0,
            "apply-to": "queues"
        }
    ],
    "queues": [
        {
            "name": "sync.branch-a",
            "vhost": "/",
            "durable": true,
            "auto_delete": false,
            "arguments": { "x-dead-letter-exchange": "mivend.sync.dlx" }
        },
        {
            "name": "sync.dead-letters",
            "vhost": "/",
            "durable": true,
            "auto_delete": false,
            "arguments": {}
        }
    ],
    "exchanges": [
        {
            "name": "mivend.sync",
            "vhost": "/",
            "type": "topic",
            "durable": true,
            "auto_delete": false,
            "internal": false,
            "arguments": {}
        },
        {
            "name": "mivend.sync.dlx",
            "vhost": "/",
            "type": "topic",
            "durable": true,
            "auto_delete": false,
            "internal": false,
            "arguments": {}
        }
    ],
    "bindings": [
        {
            "source": "mivend.sync",
            "vhost": "/",
            "destination": "sync.branch-a",
            "destination_type": "queue",
            "routing_key": "#",
            "arguments": {}
        },
        {
            "source": "mivend.sync.dlx",
            "vhost": "/",
            "destination": "sync.dead-letters",
            "destination_type": "queue",
            "routing_key": "#",
            "arguments": {}
        }
    ]
}
