        "@vendure/job-queue-plugin": "^3.0.0",
        "bullmq": "^5.0.0",
        "pg": "^8.11.0",
        "shared": "workspace:*",
        "@mivend/plugin-customer-pricing": "workspace:*",
        "@mivend/plugin-counterparty": "workspace:*",
        "@mivend/plugin-price-entry": "workspace:*",
        "@mivend/plugin-erp-import": "workspace:*",
        "@mivend/plugin-cross-reference": "workspace:*",
        "@mivend/plugin-search": "workspace:*",
        "@mivend/plugin-erp-order": "workspace:*",
